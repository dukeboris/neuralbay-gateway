# Server
PORT=3000
BASE_URL=
LOG_LEVEL=info

# Database (sqlite / mysql / postgres)
DB_TYPE=postgres
DSN=host=localhost user=newapi password=newapi123 dbname=newapi port=5432 sslmode=disable

# Redis
REDIS_CONN_STRING=redis://:redis123@localhost:6379/0
REDIS_PREFIX=new-api

# Cache
MEMORY_CACHE_ENABLED=true

# Security (REQUIRED - change these!)
SESSION_SECRET=your-session-secret-min-32-chars
CRYPTO_SECRET=your-crypto-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars

# Stripe Payment
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx

# Crypto Payment (optional)
CRYPTO_RPC_URL=https://mainnet.infura.io/v3/your-project-id

# Rate Limiting
RATE_LIMIT_COUNT=60
RATE_LIMIT_TIME=60

# Model Settings
MODEL_RETRY_COUNT=3
GEMINI_VERSION=v1

# Monitoring (optional)
PYROSCOPE_SERVER=
PYROSCOPE_APP_NAME=new-api
