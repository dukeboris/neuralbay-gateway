{
  "title": "NeuralBay Gateway",
  "uid": "neuralbay",
  "panels": [
    {
      "title": "HTTP Request Rate",
      "targets": [{"expr": "rate(neuralbay_http_requests_total[1m])"}],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Request Latency (p99)",
      "targets": [{"expr": "histogram_quantile(0.99, rate(neuralbay_http_request_duration_seconds_bucket[5m]))"}],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Relay Tokens by Model",
      "targets": [{"expr": "rate(neuralbay_relay_tokens_total[5m])"}],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "title": "Relay Requests by Status",
      "targets": [{"expr": "rate(neuralbay_relay_requests_total[5m])"}],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    },
    {
      "title": "Active Channels",
      "targets": [{"expr": "neuralbay_active_channels"}],
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 6}
    },
    {
      "title": "Active Users",
      "targets": [{"expr": "neuralbay_active_users"}],
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 6}
    },
    {
      "title": "DB Connections",
      "targets": [{"expr": "neuralbay_db_connections"}],
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 6}
    }
  ]
}
